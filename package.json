{
  "name": "@martinzachariassen/design",
  "version": "0.3.0",
  "description": "MLZ Design — Martin Zachariassen's design system: the single source of truth for colour, type, style and motion, packaged as React + Tailwind v4 tokens and components so every project inherits one consistent look.",
  "license": "MIT",
  "author": "Martin Zachariassen",
  "type": "module",
  "engines": {
    "node": ">=22.12",
    "bun": ">=1.3"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./brand-assets": {
      "types": "./dist/brand-assets.d.ts",
      "import": "./dist/brand-assets.js"
    },
    "./styles/index.css": "./dist/styles/index.css",
    "./styles/theme.css": "./dist/styles/theme.css",
    "./styles/fonts.css": "./dist/styles/fonts.css",
    "./styles/base.css": "./dist/styles/base.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && rm -rf dist/styles && cp -R src/styles dist/styles",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "serve:storybook": "node server.mjs",
    "test-storybook": "test-storybook",
    "preview": "python3 -m http.server 4321 --bind 127.0.0.1",
    "gen:swift": "bun scripts/generate-swift-tokens.ts",
    "gen:banner": "bun scripts/generate-banner.ts",
    "gen:assets": "bun scripts/brand-assets/generate.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@changesets/cli": "^2.31.1",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "axe-playwright": "^2.2.2",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinzachariassen/mlz-design.git"
  },
  "homepage": "https://github.com/martinzachariassen/mlz-design#readme",
  "bugs": {
    "url": "https://github.com/martinzachariassen/mlz-design/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "components",
    "theme"
  ],
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild"
  ]
}
