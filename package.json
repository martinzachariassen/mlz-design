{
  "name": "@martinzachariassen/design",
  "version": "0.1.0",
  "description": "MLZ design system — colour, type and style tokens plus React components for Tailwind v4 apps, distilled from mlz.no.",
  "license": "MIT",
  "author": "Martin Zachariassen",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./styles/theme.css": "./dist/styles/theme.css",
    "./styles/fonts.css": "./dist/styles/fonts.css",
    "./styles/base.css": "./dist/styles/base.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && cp -R src/styles dist/styles",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "serve:storybook": "node server.mjs",
    "preview": "python3 -m http.server 4321 --directory preview",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinzachariassen/mlz-design.git"
  },
  "homepage": "https://github.com/martinzachariassen/mlz-design#readme",
  "bugs": {
    "url": "https://github.com/martinzachariassen/mlz-design/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "components",
    "theme"
  ],
  "trustedDependencies": ["@biomejs/biome", "esbuild"]
}
